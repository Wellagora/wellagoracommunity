# Sentry Configuration (Optional - for production error tracking)
VITE_SENTRY_DSN=your-sentry-dsn-here
VITE_ENABLE_SENTRY=false

# Supabase Configuration
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe Configuration (Payment Processing)
VITE_STRIPE_ENABLED=true
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key-here

# Feature Flags — MVP v2 community-first phase (2026-05-08)
# Set to 'true' to enable the financial layer (Stripe, sponsor dashboard, vouchers, payouts, TÁMOGATOTT badge)
VITE_FEATURE_FINANCIAL_MODEL=false
# Set to 'true' to enable Carbon Handprint UI (currently hidden — methodology under development)
VITE_FEATURE_CARBON_HANDPRINT=false
# Community feed (questions + comments on /community page) — default on
VITE_FEATURE_COMMUNITY_FEED=true
# Direct messaging tag-to-tag — not in MVP, only feed/comments
VITE_FEATURE_DIRECT_MESSAGES=false
# WellBot Insights for Creators panel — default on (backend is live)
VITE_FEATURE_CREATOR_INSIGHTS=true
